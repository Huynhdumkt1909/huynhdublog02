---
import Search from "astro-pagefind/components/Search.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div id="search-modal" class="fixed inset-0 z-50 hidden items-start justify-center bg-black/40 p-4 pt-24">
  <div class="w-full max-w-lg rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-4 shadow-2xl">
    <Search
      className="pagefind-ui--custom"
      searchboxOptions={{ placeholder: t("search.placeholder"), autofocus: true }}
    />
  </div>
</div>

<script is:inline>
  (function () {
    function getModal() {
      return document.getElementById("search-modal");
    }
    function open() {
      const modal = getModal();
      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
    }
    function close() {
      const modal = getModal();
      modal?.classList.add("hidden");
      modal?.classList.remove("flex");
    }

    function init() {
      // #search-modal/#search-trigger bị tạo mới sau mỗi lần điều hướng (client router thay
      // toàn bộ <body>), nên phải gắn lại listener trên chính các element này mỗi lần init().
      // Guard dataset.bound vì astro:page-load cũng fire ở lần load đầu, trùng với nhánh
      // readyState bên dưới, nên init() có thể chạy 2 lần cho cùng 1 element (nhân đôi listener).
      const modal = getModal();
      const trigger = document.getElementById("search-trigger");
      if (!modal || modal.dataset.bound) return;
      modal.dataset.bound = "1";

      trigger?.addEventListener("click", open);
      modal.addEventListener("click", (e) => {
        if (e.target === modal) close();
      });
    }

    // Ngược lại, document tồn tại xuyên suốt mọi lần điều hướng, nên chỉ được gắn listener
    // này đúng 1 lần — gắn theo element cũ (đã bị swap) sẽ khiến nó nhân bản mỗi lần chuyển trang.
    if (!window.__searchModalKeydownBound) {
      window.__searchModalKeydownBound = true;
      document.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
          e.preventDefault();
          getModal()?.classList.contains("hidden") ? open() : close();
        }
        if (e.key === "Escape") close();
      });
    }

    if (document.readyState !== "loading") init();
    else document.addEventListener("DOMContentLoaded", init);
    document.addEventListener("astro:page-load", init);
  })();
</script>
