---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import { siteConfig } from "../site.config";
import { useTranslations, getLocalizedPath } from "../i18n/utils";
import { getPostsByLang, getAllProjects } from "../lib/content";
import type { Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = (await getPostsByLang(lang)).slice(0, 4);
const projects = (await getAllProjects()).filter((p) => p.data.featured).slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteConfig.name,
  url: siteConfig.url,
  sameAs: [siteConfig.social.github, siteConfig.social.twitter, siteConfig.social.linkedin].filter(Boolean),
};
---

<Layout title={siteConfig.name} description={siteConfig.description[lang]} jsonLd={jsonLd}>
  <section class="mx-auto max-w-[var(--wide-width)] px-6 pb-8 pt-16">
    <div class="max-w-[var(--content-width)]">
      <div class="flex flex-col items-start gap-5 sm:flex-row sm:items-center">
        <img
          src={siteConfig.avatar}
          alt={siteConfig.name}
          width="88"
          height="88"
          class="h-[88px] w-[88px] shrink-0 rounded-full object-cover ring-4 ring-[var(--color-bg-elevated)] shadow-sm"
        />
        <div>
          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{siteConfig.name}</h1>
          <p class="mt-2 text-lg leading-relaxed text-[var(--color-text-muted)]">{siteConfig.bio[lang]}</p>
        </div>
      </div>
      <a
        href={getLocalizedPath("/blog", lang)}
        class="motif-divider mt-6 inline-flex text-sm font-medium text-[var(--color-accent)]"
      >
        {t("home.intro.cta")}
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-[var(--wide-width)] px-6 py-10">
    <h2 class="mb-6 text-xl font-semibold">{t("home.recent")}</h2>
    <div class="max-w-[var(--content-width)]">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  {projects.length > 0 && (
    <section class="mx-auto max-w-[var(--wide-width)] px-6 py-10">
      <h2 class="mb-6 text-xl font-semibold">{t("home.projects")}</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <a
            href={project.data.link ?? project.data.repo ?? "#"}
            target="_blank"
            rel="noopener"
            class="block rounded-xl border border-[var(--color-border)] p-5 transition hover:border-[var(--color-accent)]"
          >
            <h3 class="font-semibold">{project.data.title}</h3>
            <p class="mt-2 text-sm text-[var(--color-text-muted)]">{project.data.description}</p>
            <p class="mt-3 text-xs text-[var(--color-text-muted)]">{project.data.stack.join(" · ")}</p>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
