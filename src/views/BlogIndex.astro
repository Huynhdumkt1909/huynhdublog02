---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import { siteConfig } from "../site.config";
import { useTranslations } from "../i18n/utils";
import { getPostsByLang } from "../lib/content";
import type { Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = await getPostsByLang(lang);
---

<Layout title={t("nav.blog")} description={siteConfig.description[lang]}>
  <section class="mx-auto max-w-[var(--wide-width)] px-6 py-12">
    <h1 class="mb-8 text-3xl font-bold tracking-tight sm:text-4xl">{t("nav.blog")}</h1>
    <div class="grid grid-cols-1 gap-6 sm:block sm:gap-0">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</Layout>
