---
import { getLangFromUrl, getDefaultAlternatePath } from "../i18n/utils";
import { languages } from "../i18n/ui";

interface Props {
  // đường dẫn chính xác sang ngôn ngữ kia; truyền khi slug 2 ngôn ngữ khác nhau (vd bài blog)
  altPath?: string;
}

const { altPath } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const otherLang = lang === "vi" ? "en" : "vi";
const otherPath = altPath ?? getDefaultAlternatePath(Astro.url.pathname, lang);
---

<a
  href={otherPath}
  class="text-sm font-medium text-[var(--color-text-muted)] transition hover:text-[var(--color-accent)]"
  aria-label={`Switch to ${languages[otherLang]}`}
>
  {otherLang.toUpperCase()}
</a>
