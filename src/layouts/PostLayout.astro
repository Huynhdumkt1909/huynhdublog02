---
import type { MarkdownHeading } from "astro";
import Layout from "./Layout.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import Remark42Comments from "../components/Remark42Comments.astro";
import Newsletter from "../components/Newsletter.astro";
import ShareButtons from "../components/ShareButtons.astro";
import AuthorByline from "../components/AuthorByline.astro";
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/utils";
import { siteConfig } from "../site.config";
import { getPostByTranslationKey, postSlug } from "../lib/content";
import { personJsonLd } from "../lib/seo";
import type { Lang } from "../i18n/ui";

interface Props {
  title: string;
  excerpt: string;
  publishedDate: Date;
  updatedDate?: Date;
  tags: string[];
  headings: MarkdownHeading[];
  minutes: number;
  translationKey?: string;
  cover?: string;
  seo?: { title?: string; description?: string; ogImage?: string };
}

const { title, excerpt, publishedDate, updatedDate, tags, headings, minutes, translationKey, cover, seo } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const otherLang: Lang = lang === "vi" ? "en" : "vi";
const translatedPost = translationKey ? await getPostByTranslationKey(otherLang, translationKey) : undefined;
const altPath = translatedPost
  ? getLocalizedPath(`/blog/${postSlug(translatedPost)}`, otherLang)
  : getLocalizedPath("/blog", otherLang);

const seoTitle = seo?.title ?? title;
const seoDescription = seo?.description ?? excerpt;
const seoImage = seo?.ogImage ?? cover;

const dateFormatted = publishedDate.toLocaleDateString(lang === "vi" ? "vi-VN" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: excerpt,
  datePublished: publishedDate.toISOString(),
  dateModified: (updatedDate ?? publishedDate).toISOString(),
  author: personJsonLd(lang),
  inLanguage: lang,
};

const topHeadings = headings.filter((h) => h.depth <= 3);
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).toString();
---

<Layout
  title={seoTitle}
  description={seoDescription}
  type="article"
  image={seoImage}
  publishedDate={publishedDate}
  updatedDate={updatedDate}
  tags={tags}
  jsonLd={jsonLd}
  altPath={altPath}
>
  <ReadingProgress />
  <div class="mx-auto grid max-w-[var(--wide-width)] grid-cols-1 gap-10 px-6 py-12 lg:grid-cols-[minmax(0,var(--content-width))_14rem]">
    <article data-article>
      <a href={getLocalizedPath("/blog", lang)} class="motif-divider mb-6 inline-flex text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)]">
        {t("blog.backToBlog")}
      </a>
      <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">{title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-muted)]">
        <span>{t("blog.publishedOn")} {dateFormatted}</span>
        <span>&middot;</span>
        <span>{minutes} {t("blog.minRead")}</span>
        {tags.length > 0 && <span>&middot;</span>}
        {tags.map((tag) => (
          <span
            class="rounded-full px-2 py-0.5 text-xs font-medium"
            style="background-color: var(--color-accent-secondary-soft); color: var(--color-accent-secondary)"
          >
            {tag}
          </span>
        ))}
      </div>

      <div class="mt-4">
        <AuthorByline />
      </div>

      <div class="mt-4">
        <ShareButtons url={canonicalUrl} title={title} />
      </div>

      {topHeadings.length > 0 && (
        <details class="mt-6 rounded-lg border border-[var(--color-border)] p-3 lg:hidden">
          <summary class="cursor-pointer text-sm font-semibold">{t("blog.tableOfContents")}</summary>
          <nav class="mt-3 space-y-2 text-sm">
            {topHeadings.map((h) => (
              <a
                href={`#${h.slug}`}
                class="block text-[var(--color-text-muted)] hover:text-[var(--color-accent)]"
                style={`padding-left: ${(h.depth - Math.min(...topHeadings.map((x) => x.depth))) * 0.75}rem`}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </details>
      )}

      <div class="prose-content mt-8">
        <slot />
      </div>

      <div class="mt-12">
        <Newsletter />
      </div>

      <div class="mt-12 border-t border-[var(--color-border)] pt-8">
        <h2 class="mb-4 text-lg font-semibold">{t("blog.comments")}</h2>
        <Remark42Comments />
      </div>
    </article>

    {topHeadings.length > 0 && (
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
            {t("blog.tableOfContents")}
          </p>
          <nav class="space-y-2 text-sm">
            {topHeadings.map((h) => (
              <a
                href={`#${h.slug}`}
                class="block text-[var(--color-text-muted)] hover:text-[var(--color-accent)]"
                style={`padding-left: ${(h.depth - Math.min(...topHeadings.map((x) => x.depth))) * 0.75}rem`}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    )}
  </div>
</Layout>
