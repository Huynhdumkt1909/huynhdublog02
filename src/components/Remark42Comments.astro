---
import { siteConfig } from "../site.config";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { host, siteId } = siteConfig.remark42;
---

{host && siteId && (
  <>
    <div id="remark42"></div>
    <script is:inline define:vars={{ host, siteId, lang }}>
      (function () {
        function init() {
          const isDark = document.documentElement.classList.contains("dark");
          window.remark_config = {
            host,
            site_id: siteId,
            components: ["embed"],
            theme: isDark ? "dark" : "light",
            locale: lang === "vi" ? "vi" : "en",
          };
          const mount = document.getElementById("remark42");
          if (!mount) return;
          mount.innerHTML = "";

          // Sau lần đầu, module embed.mjs đã được trình duyệt cache theo URL nên chèn lại
          // <script type=module> không chạy lại nữa (spec ES module). Remark42 cung cấp sẵn
          // createInstance() để remount đúng bài viết mới khi chuyển trang bằng client router.
          if (window.REMARK42 && typeof window.REMARK42.createInstance === "function") {
            window.REMARK42.createInstance(window.remark_config);
            return;
          }

          (function (e, n) {
            for (let o = 0; o < e.length; o++) {
              const r = n.createElement("script");
              let c = ".js";
              const d = n.head || n.body;
              if ("noModule" in r) {
                r.type = "module";
                c = ".mjs";
              } else {
                r.async = true;
                r.defer = true;
              }
              r.src = window.remark_config.host + "/web/" + e[o] + c;
              d.appendChild(r);
            }
          })(window.remark_config.components || ["embed"], document);
        }

        document.addEventListener("astro:page-load", init);
        if (document.readyState !== "loading") init();
        else document.addEventListener("DOMContentLoaded", init);

        // document persists qua client-side nav còn init() re-chạy mỗi lần điều hướng
        // (event page-load); nếu không guard bằng cờ toàn cục, listener dưới đây sẽ nhân bản
        // sau mỗi lần chuyển trang thay vì chỉ đăng ký đúng 1 lần.
        if (!window.__remark42ThemeSyncBound) {
          window.__remark42ThemeSyncBound = true;
          document.addEventListener("click", (e) => {
            if (e.target.closest?.("#theme-toggle") && window.REMARK42) {
              setTimeout(() => {
                const isDark = document.documentElement.classList.contains("dark");
                window.REMARK42.changeTheme(isDark ? "dark" : "light");
              }, 0);
            }
          });
        }
      })();
    </script>
    <noscript>Vui lòng bật JavaScript để xem bình luận (Remark42).</noscript>
  </>
)}
