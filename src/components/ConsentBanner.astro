---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
  id="consent-banner"
  class="fixed inset-x-4 bottom-4 z-50 hidden max-w-md rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-4 shadow-lg sm:left-4 sm:right-auto"
>
  <p class="mb-3 text-sm text-[var(--color-text-muted)]">{t("consent.message")}</p>
  <div class="flex gap-2">
    <button
      id="consent-accept"
      type="button"
      class="rounded-full px-4 py-1.5 text-sm font-medium"
      style="background-color: var(--color-accent); color: var(--color-on-accent)"
    >
      {t("consent.accept")}
    </button>
    <button
      id="consent-decline"
      type="button"
      class="rounded-full border border-[var(--color-border)] px-4 py-1.5 text-sm font-medium text-[var(--color-text-muted)]"
    >
      {t("consent.decline")}
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    function init() {
      var banner = document.getElementById("consent-banner");
      if (!banner || banner.dataset.bound) return;
      banner.dataset.bound = "1";
      var choice = localStorage.getItem("consent");
      if (!choice) banner.classList.remove("hidden");

      document.getElementById("consent-accept")?.addEventListener("click", function () {
        localStorage.setItem("consent", "granted");
        banner.classList.add("hidden");
        if (window.gtag) {
          // Banner chỉ xin đồng ý đo lường truy cập (analytics), không nhắc tới quảng cáo —
          // nên chỉ grant analytics_storage. Nếu sau này thêm Meta Pixel/TikTok Pixel, phải
          // sửa lại nội dung banner (consent.message) TRƯỚC rồi mới được grant thêm ad_*.
          window.gtag("consent", "update", {
            ad_storage: "denied",
            ad_user_data: "denied",
            ad_personalization: "denied",
            analytics_storage: "granted",
          });
        }
        window.__loadGTM?.();
      });

      document.getElementById("consent-decline")?.addEventListener("click", function () {
        localStorage.setItem("consent", "denied");
        banner.classList.add("hidden");
      });
    }
    if (document.readyState !== "loading") init();
    else document.addEventListener("DOMContentLoaded", init);
    document.addEventListener("astro:page-load", init);
  })();
</script>
